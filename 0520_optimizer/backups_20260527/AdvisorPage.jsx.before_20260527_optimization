import React, { useState, useRef, useEffect, useCallback } from "react";
import ThinkingPanel from "../components/advisor/ThinkingPanel";
import CollapsedThinkingLog from "../components/advisor/CollapsedThinkingLog";
import MessageBubble from "../components/advisor/MessageBubble";
import ToolResultCard from "../components/advisor/ToolResultCard";
import { streamAdvisorChat } from "../api/advisorApi";
import * as advisorDB from "../utils/advisorDB";

const TOOL_LABELS = {
  search_symptom: "搜尋症狀相關營養素",
  search_graphrag: "查詢學術文獻",
  get_nutrient_ranking: "查詢營養素排名",
  search_food: "搜尋食物資訊",
  get_diet_logs: "查詢飲食日誌",
  add_diet_log: "新增飲食記錄",
  update_diet_log: "修改飲食記錄",
  delete_diet_log: "刪除飲食記錄",
  get_saved_recipes: "查詢已儲存食譜",
  get_calendar_entries: "查詢行事曆",
  add_to_calendar: "加入行事曆",
  delete_calendar_entry: "刪除行事曆紀錄",
  get_user_profile: "讀取個人資料",
  update_user_profile: "更新個人資料",
};

export default function AdvisorPage() {
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [steps, setSteps] = useState([]);
  const [isThinking, setIsThinking] = useState(false);
  const [memory, setMemory] = useState("");
  const [workflowState, setWorkflowState] = useState({});
  const [narrativeMemory, setNarrativeMemory] = useState("");
  const [structuredStore, setStructuredStore] = useState({});
  const [phaseSteps, setPhaseSteps] = useState([]);
  const [liveThinking, setLiveThinking] = useState([]);
  const [sessionId, setSessionId] = useState("");
  const [showResumePrompt, setShowResumePrompt] = useState(false);
  const [collectingState, setCollectingState] = useState(null);
  const [dbReady, setDbReady] = useState(false);
  const chatEndRef = useRef(null);
  const abortRef = useRef(null);

  useEffect(() => {
    (async () => {
      try {
        if (advisorDB.isSupported()) {
          await advisorDB.migrateFromLocalStorage();
        }
        const sid = await advisorDB.loadState("session_id") || "";
        const msgs = sid ? await advisorDB.loadMessages(sid) : [];
        const narr = await advisorDB.loadState("narrative_memory") || "";
        const store = await advisorDB.loadState("structured_store") || {};
        const ws = await advisorDB.loadState("workflow_state") || {};
        setSessionId(sid);
        setMessages(msgs);
        setNarrativeMemory(narr);
        setStructuredStore(store);
        setWorkflowState(ws);
        if (sid && msgs.length > 0) {
          setShowResumePrompt(true);
        }
      } catch {
        // IndexedDB 不可用時保持空狀態
      }
      setDbReady(true);
    })();
  }, []);

  useEffect(() => {
    chatEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages, steps]);

  useEffect(() => {
    if (!dbReady) return;
    if (sessionId && messages.length > 0) {
      advisorDB.saveMessages(sessionId, messages).catch(() => {});
    }
  }, [messages, dbReady, sessionId]);

  const handleSend = useCallback((overrideText) => {
    const text = (overrideText || input).trim();
    if (!text || isLoading) return;

    const isHidden = typeof overrideText === "string" && overrideText.startsWith("[RECIPE_CONFIRM]");
    const userMsg = { role: "user", content: isHidden ? "(確認食材中...)" : text, _hidden: isHidden, _rawText: text };
    const newMessages = [...messages, userMsg];
    setMessages(newMessages);
    if (!overrideText) setInput("");
    setIsLoading(true);
    setIsThinking(true);
    setSteps([]);
    setPhaseSteps([]);

    let turnTools = [];
    let turnToolResults = [];
    let turnSteps = [];
    let turnPhases = [];
    let turnThinkingSteps = [];

    const history = newMessages.slice(0, -1).map((m) => ({
      role: m.role,
      content: m.content,
      tools_used: m.tools_used || [],
    }));

    let echoMsgAdded = false;

    const { abort } = streamAdvisorChat(text, history, {}, {
      onThinking() {
        setIsThinking(true);
      },
      onThinkingStart(data) {
        const entry = { step: data.step, label: data.label, content: "", done: false };
        turnThinkingSteps = [...turnThinkingSteps, entry];
        setLiveThinking([...turnThinkingSteps]);
        setSteps((prev) => {
          const label = data.label || data.step;
          return [
            ...prev.map((s) => ({ ...s, status: s.status === "active" ? "done" : s.status })),
            { label: `💭 ${label}`, status: "active", summary: "" },
          ];
        });
      },
      onThinkingDelta(data) {
        turnThinkingSteps = turnThinkingSteps.map((ts) =>
          ts.step === data.step && !ts.done
            ? { ...ts, content: ts.content + (data.content || "") }
            : ts
        );
        setLiveThinking([...turnThinkingSteps]);
      },
      onThinkingEnd(data) {
        turnThinkingSteps = turnThinkingSteps.map((ts) =>
          ts.step === data.step ? { ...ts, done: true } : ts
        );
        setLiveThinking([...turnThinkingSteps]);
        setSteps((prev) =>
          prev.map((s) =>
            s.status === "active" && s.label.startsWith("💭")
              ? { ...s, status: "done", summary: "完成" }
              : s
          )
        );
      },
      onEcho(data) {
        if (data.content && !echoMsgAdded) {
          echoMsgAdded = true;
          setMessages((prev) => [...prev, {
            role: "assistant",
            content: data.content,
            _isEcho: true,
          }]);
          setIsThinking(false);
        }
      },
      onToolStart(data) {
        const label = TOOL_LABELS[data.name] || data.name;
        turnSteps = [
          ...turnSteps.map((s) => ({ ...s, status: "done" })),
          { label, status: "active", summary: "", startTime: Date.now() },
        ];
        setSteps([...turnSteps]);
      },
      onToolDone(data) {
        turnTools.push({ name: data.name, summary: data.summary });
        turnSteps = turnSteps.map((s) =>
          s.status === "active" ? { ...s, status: "done", summary: data.summary } : s
        );
        setSteps([...turnSteps]);
      },
      onToolProgress(data) {
        turnSteps = turnSteps.map((s) =>
          s.status === "active"
            ? { ...s, progress: data.progress, progressLabel: data.label }
            : s
        );
        setSteps([...turnSteps]);
      },
      onToolResult(data) {
        turnToolResults.push({ name: data.name, data: data.data });
      },
      onMemory(data) {
        if (data.summary) setMemory(data.summary);
      },
      onPhaseStatus(data) {
        if (data.phase && !turnPhases.includes(data.phase)) {
          turnPhases = [...turnPhases, data.phase];
          setPhaseSteps([...turnPhases]);
        }
      },
      onNarrativeMemory(data) {
        if (data.summary) {
          setNarrativeMemory(data.summary);
          advisorDB.saveState("narrative_memory", data.summary).catch(() => {});
        }
      },
      onStructuredStore(data) {
        if (data.store) {
          setStructuredStore(data.store);
          advisorDB.saveState("structured_store", data.store).catch(() => {});
        }
      },
      onWorkflowState(data) {
        setWorkflowState(data || {});
        advisorDB.saveState("workflow_state", data || {}).catch(() => {});
        if (data?.phase !== "collecting") setCollectingState(null);
      },
      onCollectingState(data) {
        setCollectingState(data || null);
      },
      onSessionId(data) {
        if (data.session_id) {
          setSessionId(data.session_id);
          advisorDB.saveState("session_id", data.session_id).catch(() => {});
          advisorDB.saveSession({ id: data.session_id, title: "" }).catch(() => {});
        }
      },
      onCheckpointSaved() {},
      onReply(data) {
        const snapshotResults = [...turnToolResults];
        const snapshotTools = [...turnTools];
        const snapshotSteps = turnSteps.map((s) => ({ ...s, status: "done" }));
        const snapshotPhases = [...turnPhases];
        const snapshotThinking = [...turnThinkingSteps];
        setMessages((prev) => {
          const filtered = echoMsgAdded
            ? prev.filter((m) => !m._isEcho)
            : prev;
          return [...filtered, {
            role: "assistant",
            content: data.content,
            tools_used: snapshotTools,
            tool_results: snapshotResults,
            thinking_steps: snapshotSteps,
            phase_steps: snapshotPhases,
            thinking_content: snapshotThinking,
          }];
        });
        turnTools = [];
        turnToolResults = [];
        turnSteps = [];
        turnPhases = [];
        turnThinkingSteps = [];
        setSteps([]);
        setPhaseSteps([]);
        setLiveThinking([]);
        setIsLoading(false);
        setIsThinking(false);
      },
      onError(errMsg) {
        setMessages((prev) => [
          ...prev,
          { role: "assistant", content: `⚠️ ${errMsg}` },
        ]);
        setSteps([]);
        setPhaseSteps([]);
        setIsLoading(false);
        setIsThinking(false);
      },
      onComplete() {
        setIsLoading(false);
        setIsThinking(false);
      },
    }, memory, workflowState, narrativeMemory, structuredStore, sessionId);

    abortRef.current = abort;
  }, [input, isLoading, messages, memory, workflowState, narrativeMemory, structuredStore, sessionId]);

  const handleConfirmAction = useCallback((payload) => {
    const msg = `[RECIPE_CONFIRM]${JSON.stringify(payload)}`;
    handleSend(msg);
  }, [handleSend]);

  const handleKeyDown = (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  };

  const handleClear = () => {
    if (sessionId) {
      const token = localStorage.getItem("token");
      fetch(`/api/conversations/sessions/${sessionId}?user_id=0`, {
        method: "DELETE",
        headers: { Authorization: `Bearer ${token}` },
      }).catch(() => {});
      advisorDB.clearSession(sessionId).catch(() => {});
    } else {
      advisorDB.clearAllState().catch(() => {});
    }
    setMessages([]);
    setSteps([]);
    setMemory("");
    setWorkflowState({});
    setNarrativeMemory("");
    setStructuredStore({});
    setPhaseSteps([]);
    setSessionId("");
    setShowResumePrompt(false);
    setCollectingState(null);
  };

  const handleResume = () => {
    setShowResumePrompt(false);
  };

  const handleNewChat = () => {
    handleClear();
  };

  return (
    <div style={pageStyles.container}>
      <div style={pageStyles.header}>
        <h2 style={pageStyles.title}>🤖 AI 營養顧問</h2>
        <p style={pageStyles.subtitle}>
          告訴我你的飲食、症狀、或營養問題，我會幫你分析並給出建議。
        </p>
      </div>

      <div style={pageStyles.chatArea}>
        {showResumePrompt && (
          <div style={pageStyles.resumeBanner}>
            <span>📌 偵測到上次未完成的對話</span>
            <div style={{ display: "flex", gap: 8, marginTop: 8 }}>
              <button style={pageStyles.resumeBtn} onClick={handleResume}>繼續對話</button>
              <button style={pageStyles.newChatBtn} onClick={handleNewChat}>開始新對話</button>
            </div>
          </div>
        )}
        <div style={pageStyles.placeholder}>
          <div style={pageStyles.welcomeBubble}>
            <p style={{ margin: "0 0 8px", fontWeight: 600 }}>你好！我是你的 AI 營養顧問 👋</p>
            <p style={{ margin: 0, lineHeight: 1.6 }}>
              我可以幫你：記錄飲食並自動計算營養、分析你的 DRI 缺口、搜尋食物營養成分、根據症狀推薦營養素與食物、查詢學術文獻佐證，以及管理你的飲食日誌和食譜。
            </p>
            <p style={{ margin: "8px 0 0", color: "#718096", fontSize: 13 }}>點擊下方按鈕快速開始，或直接輸入你的問題：</p>
          </div>
          <div style={pageStyles.suggestionGroups}>
            <div style={pageStyles.suggestionGroup}>
              <span style={pageStyles.groupLabel}>📋 記錄飲食</span>
              <button style={pageStyles.suggestionBtn} onClick={() => { setInput("今天午餐吃了雞腿便當、青菜、荷包蛋"); }}>今天午餐吃了雞腿便當、青菜、荷包蛋</button>
            </div>
            <div style={pageStyles.suggestionGroup}>
              <span style={pageStyles.groupLabel}>📊 營養分析</span>
              <button style={pageStyles.suggestionBtn} onClick={() => { setInput("我25歲女性，幫我看看營養是否充足"); }}>我25歲女性，幫我看看營養是否充足</button>
              <button style={pageStyles.suggestionBtn} onClick={() => { setInput("哪些食物鎂含量最高？"); }}>哪些食物鎂含量最高？</button>
            </div>
            <div style={pageStyles.suggestionGroup}>
              <span style={pageStyles.groupLabel}>🩺 症狀查詢</span>
              <button style={pageStyles.suggestionBtn} onClick={() => { setInput("最近常覺得疲勞，有什麼營養建議？"); }}>最近常覺得疲勞，有什麼營養建議？</button>
            </div>
            <div style={pageStyles.suggestionGroup}>
              <span style={pageStyles.groupLabel}>📚 學術文獻</span>
              <button style={pageStyles.suggestionBtn} onClick={() => { setInput("為什麼蛋白質對肌肉修復很重要？"); }}>為什麼蛋白質對肌肉修復很重要？</button>
            </div>
            <div style={pageStyles.suggestionGroup}>
              <span style={pageStyles.groupLabel}>🔍 食物搜尋</span>
              <button style={pageStyles.suggestionBtn} onClick={() => { setInput("雞胸肉的營養成分是什麼？"); }}>雞胸肉的營養成分是什麼？</button>
            </div>
          </div>
        </div>

        {messages.map((msg, i) => (
          <React.Fragment key={i}>
            {msg.role === "assistant" && (msg.thinking_steps?.length > 0 || msg.thinking_content?.length > 0) && (
              <CollapsedThinkingLog steps={msg.thinking_steps} phases={msg.phase_steps} thinkingContent={msg.thinking_content} />
            )}
            {msg.role === "assistant" && msg.tool_results?.length > 0 && (
              msg.tool_results.map((tr, j) => (
                <ToolResultCard key={`tr-${i}-${j}`} name={tr.name} data={tr.data} onAction={handleConfirmAction} />
              ))
            )}
            <MessageBubble role={msg.role} content={msg.content} />
          </React.Fragment>
        ))}

        {isLoading && (
          <ThinkingPanel steps={steps} isThinking={isThinking} phaseSteps={phaseSteps} thinkingContent={liveThinking} />
        )}

        <div ref={chatEndRef} />
      </div>

      <div style={pageStyles.inputArea}>
        {collectingState && (
          <div style={pageStyles.collectingBanner}>
            <div style={pageStyles.collectingHeader}>
              <span style={pageStyles.collectingDot} />
              <span>正在收集：{collectingState.intent_label} — 缺少：{collectingState.missing_label}</span>
              <span style={pageStyles.collectingTurn}>（{collectingState.turn_count}/{collectingState.max_turns}）</span>
            </div>
            {collectingState.quick_replies?.length > 0 && (
              <div style={pageStyles.quickReplies}>
                {collectingState.quick_replies.map((qr) => (
                  <button
                    key={qr}
                    style={pageStyles.quickReplyBtn}
                    onClick={() => { setInput(qr); }}
                  >
                    {qr}
                  </button>
                ))}
              </div>
            )}
          </div>
        )}
        <textarea
          style={{
            ...pageStyles.input,
            ...(collectingState ? { borderColor: "#4299e1", boxShadow: "0 0 0 2px rgba(66,153,225,0.15)" } : {}),
          }}
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={handleKeyDown}
          placeholder={collectingState?.placeholder || "輸入你的問題...（Enter 送出，Shift+Enter 換行）"}
          rows={2}
          disabled={isLoading}
        />
        <div style={pageStyles.actions}>
          <button
            style={{
              ...pageStyles.sendBtn,
              opacity: isLoading || !input.trim() ? 0.5 : 1,
            }}
            onClick={handleSend}
            disabled={isLoading || !input.trim()}
          >
            {isLoading ? "思考中..." : "送出 ▶"}
          </button>
          {messages.length > 0 && (
            <button style={pageStyles.clearBtn} onClick={handleClear}>
              清除對話
            </button>
          )}
        </div>
      </div>
    </div>
  );
}

